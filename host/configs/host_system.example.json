{
  "system": {
    "name": "sensor-system-demo",
    "site": "lab",
    "timezone": "Europe/Warsaw"
  },
  "storage": {
    "root_dir": "runs/sensor-system",
    "format": "hdf5",
    "compression": "gzip",
    "window_seconds": 600
  },
  "supervisor": {
    "status_file": "/tmp/sensor-system_supervisor_status.json",
    "event_log": "/tmp/sensor-system_supervisor_events.jsonl",
    "channel_runtime_dir": "/tmp/sensor-system_channels",
    "status_interval_s": 1.0,
    "restart_delay_s": 2.0
  },
  "channels": [
    {
      "name": "line-a",
      "label": "Linia A",
      "enabled": true,
      "port": "/dev/sensor-system-rs485-a",
      "baud": 115200,
      "nodes": [
        {
          "id": 1,
          "name": "Czujnik 1",
          "enabled": true,
          "expected_odr_hz": 125
        },
        {
          "id": 2,
          "name": "Czujnik 2",
          "enabled": false,
          "expected_odr_hz": 125
        }
      ]
    },
    {
      "name": "line-b",
      "label": "Linia B",
      "enabled": false,
      "port": "/dev/sensor-system-rs485-b",
      "baud": 115200,
      "nodes": [
        {
          "id": 10,
          "name": "Czujnik 10",
          "enabled": true,
          "expected_odr_hz": 250
        }
      ]
    }
  ]
}
